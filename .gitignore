# Data — kept outside the repo
data/
VIDEO*/
*.mp4
*.MP4
*.csv
*.dtlog
Rov_Immagine.docx

# Outputs
out/

# SAM 3 post-processing outputs (regenerable; live alongside pipeline runs).
# Already covered by out/, but listed explicitly so that SAM outputs land in
# .gitignore wherever they're produced. Curated examples for the repo live
# under demo/ instead, which is tracked.
sam3/
sam3_verification/

# Eval — extracted GT images derive from the private docx; results
# are per-config and not worth versioning. The annotation JSONs ARE
# tracked.
eval/gt_images/
eval/results/

# Model cache (HF will manage this in ~/.cache; just in case)
.huggingface/

# Secrets (even though we don't use API in default flow)
.env
rovenv

